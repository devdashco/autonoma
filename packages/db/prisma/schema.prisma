// ─── Previewkit ─────────────────────────────────────────────────────

enum PreviewkitStatus {
  pending
  building
  deploying
  ready
  failed
  // A deploy cancelled because a newer commit superseded it. Written to the
  // superseded build row only; the environment row stays owned by the newest
  // run, so this value never lands on PreviewkitEnvironment.
  superseded
  torn_down

  @@map("previewkit_status")
}

enum PreviewkitAppBuildStatus {
  success
  failed

  @@map("previewkit_app_build_status")
}

// Full per-app lifecycle status, tracked on PreviewkitAppInstance from the
// moment the resolved config names the apps (moment 0). The happy path is
// pending -> building -> built -> deploying -> ready. `build_failed` /
// `deploy_failed` are terminal failures (reason in `error`); `skipped` means
// an upstream build failure meant the deploy was never attempted.
enum PreviewkitAppStatus {
  pending
  building
  built
  deploying
  ready
  build_failed
  deploy_failed
  skipped

  @@map("previewkit_app_status")
}

model PreviewkitEnvironment {
  id String @id @default(cuid())

  // Identity — matches the K8s namespace naming: preview-{owner}-{repo}-pr-{N}
  namespace          String @unique
  repoFullName       String @map("repo_full_name")
  prNumber           Int    @map("pr_number")
  headSha            String @map("head_sha")
  headRef            String @map("head_ref")
  githubRepositoryId Int?   @map("github_repository_id")

  status PreviewkitStatus @default(pending)
  phase  String?
  error  String?

  // GitHub PR comment Previewkit updates through the lifecycle
  commentId String? @map("comment_id")

  /// ![Record<string, string>]
  urls Json @default("{}")

  bypassToken String? @map("bypass_token")

  // The effective (merged) config for the latest deploy attempt: the primary
  // app's config merged with any multirepo dependencies. The summary +
  // readiness views project it for display and failure diagnostics - there is
  // no separate manifest column. Overwritten on each deploy once the config
  // resolves. Not read on redeploy - that re-resolves the Application's
  // current config.
  /// ![object]
  resolvedConfig Json? @map("resolved_config")

  deployedAt DateTime? @map("deployed_at")
  tornDownAt DateTime? @map("torn_down_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // The autonoma Branch this environment's PR maps to. Made explicit here rather than reconstructed at runtime
  // from (githubRepositoryId, prNumber). Nullable: environments for repos with no onboarded Application (and
  // the main-branch env 0) have no branch. SetNull so deleting a branch unlinks the env instead of deleting it.
  branchId String? @unique @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  builds       PreviewkitBuild[]
  appInstances PreviewkitAppInstance[]
  addons       PreviewkitAddon[]

  @@unique([repoFullName, prNumber])
  @@index([organizationId, status])
  @@map("previewkit_environment")
}

enum GitHubPrCommentKind {
  preview
  runs
  investigation

  @@map("github_pr_comment_kind")
}

model GitHubPrComment {
  id           String              @id @default(cuid())
  repoFullName String              @map("repo_full_name")
  prNumber     Int                 @map("pr_number")
  kind         GitHubPrCommentKind
  commentId    String?             @map("comment_id")
  headSha      String?             @map("head_sha")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([repoFullName, prNumber, kind])
  @@map("github_pr_comment")
}

model PreviewkitBuild {
  id String @id @default(cuid())

  environmentId String                @map("environment_id")
  environment   PreviewkitEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  headSha    String           @map("head_sha")
  status     PreviewkitStatus @default(pending)
  error      String?
  startedAt  DateTime         @default(now()) @map("started_at")
  finishedAt DateTime?        @map("finished_at")
  durationMs Int?             @map("duration_ms")

  appBuilds PreviewkitAppBuild[]

  // One build row per (environment, commit). Makes recordBuildFinished an
  // idempotent upsert so a Temporal activity retry updates the existing row
  // instead of inserting a duplicate.
  @@unique([environmentId, headSha])
  @@index([environmentId, startedAt])
  @@map("previewkit_build")
}

// One row per app built within a PreviewkitBuild. Normalized out of what used
// to be the `app_builds` JSON column so each app's outcome is a typed,
// queryable row. Apps build independently, so one app's failure leaves the
// others' rows intact. `imageTag` is set on success; `error` on failure;
// `logUrl` is a legacy column from the retired S3 log archive - kept for
// historic rows, never written anymore (build logs are served from Loki).
model PreviewkitAppBuild {
  id String @id @default(cuid())

  buildId String          @map("build_id")
  build   PreviewkitBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)

  appName    String                   @map("app_name")
  status     PreviewkitAppBuildStatus
  imageTag   String?                  @map("image_tag")
  durationMs Int                      @map("duration_ms")
  logUrl     String?                  @map("log_url")
  error      String?
  // Build strategy that produced the image: "node" | "docker-image" | "unknown".
  // Stored as text (not an enum) because the value has a hyphen and the reader
  // treats it loosely when picking a service icon.
  runtime String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([buildId, appName])
  @@map("previewkit_app_build")
}

// One row per app per environment - the per-app lifecycle record and the
// source of truth for an app's status. Created at moment 0 (as `pending`, as
// soon as the resolved config names the apps) and transitioned through build
// and deploy, so a built-but-undeployed app (e.g. one that failed readiness
// while its siblings came up) is a distinct, queryable row rather than an
// inferred absence. `imageTag` is null until the build succeeds; `error`
// carries the reason for a `build_failed` / `deploy_failed` status.
model PreviewkitAppInstance {
  id String @id @default(cuid())

  environmentId String                @map("environment_id")
  environment   PreviewkitEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  appName  String              @map("app_name")
  status   PreviewkitAppStatus @default(pending)
  imageTag String?             @map("image_tag")
  error    String?
  url      String?
  port     Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([environmentId, appName])
  // Serves the Prometheus build-load gauge (apps/api/src/metrics), which
  // counts fresh `building` rows on every scrape - without it each scrape
  // seq-scans a table that only ever grows.
  @@index([status, updatedAt])
  @@map("previewkit_app_instance")
}

model PreviewkitSecret {
  id            String @id @default(cuid())
  applicationId String @map("application_id")
  appName       String @map("app_name")
  awsSecretArn  String @map("aws_secret_arn")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([applicationId, appName])
  @@index([applicationId])
  @@map("previewkit_secret")
}

// Org-scoped credentials referenced by preview config addons via the
// `auth_secret` field. Stored in AWS Secrets Manager as a JSON map (matching
// the per-app PreviewkitSecret pattern); each provider's options schema picks
// the key it needs (e.g. NeonProvider expects `token`).
model PreviewkitOrgSecret {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  name           String
  awsSecretArn   String @map("aws_secret_arn")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("previewkit_org_secret")
}

// An Application's preview config document - latest-only, one row per
// Application (no revision history; saving overwrites the row in place).
// `document` is a preview config document validated against
// `previewConfigSchema`; it is stored as opaque JSON and validated on read by
// the resolver (boundary validation), so the DB never constrains a churning
// config format. There is no stored `schemaVersion`: `previewConfigSchema` is
// the compatibility layer (it strips retired fields and defaults their
// replacements), so every stored document parses without a version-upgrade step.
model PreviewkitConfig {
  id            String @id @default(cuid())
  applicationId String @unique @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Opaque config document; validated by previewConfigSchema on read.
  /// ![object]
  document Json

  // Multirepo dependency configs owned by this (primary) config: an array of
  // { repo, document } where document is a previewConfigSchema-validated config
  // for a repo declared in `document.config.multirepo.repos`. Dependency repos
  // are NOT separate Applications - the primary app owns the whole topology and
  // the deploy reads each dependency's config from here (cloning the repo for
  // source only). Null/absent means a single-repo project.
  /// ![object]
  dependencyDocuments Json?  @map("dependency_documents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("previewkit_config")
}

enum PreviewkitAddonStatus {
  pending
  ok
  failed
  deprovisioned

  @@map("previewkit_addon_status")
}

// One row per (environment, addon name) — the provisioned state of a
// third-party resource (Neon branch, etc.). `outputs` are surfaced into
// the template engine so apps can reference {{addonName.<key>}} in env
// and build_args. On re-push, rows with status=ok replay cached outputs;
// rows in any other status are re-attempted.
model PreviewkitAddon {
  id            String                @id @default(cuid())
  environmentId String                @map("environment_id")
  environment   PreviewkitEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  name     String
  provider String

  status PreviewkitAddonStatus @default(pending)
  error  String?

  /// [PreviewkitAddonState]
  state Json @default("{}")

  /// [PreviewkitAddonOutputs]
  outputs Json @default("{}")

  provisionedAt   DateTime? @map("provisioned_at")
  deprovisionedAt DateTime? @map("deprovisioned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([environmentId, name])
  @@index([environmentId])
  @@map("previewkit_addon")
}

// ─── Diffs Job ────────────────────────────────────────────────────────────────

enum DiffsJobStatus {
  pending
  analyzing
  replaying
  resolving
  generating
  finalizing
  completed
  failed

  @@map("diffs_job_status")
}

enum AffectedReason {
  code_change
  merge_plan_imported
  merge_conflict

  @@map("affected_reason")
}

model DiffsJob {
  snapshotId String         @id @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  status DiffsJobStatus @default(pending)

  analysisReasoning   String? @map("analysis_reasoning") @db.Text
  resolutionReasoning String? @map("resolution_reasoning") @db.Text
  failureReason       String? @map("failure_reason") @db.Text

  analysisConversationUrl String? @map("analysis_conversation_url")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  affectedTests AffectedTest[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("diffs_job")
}

enum InvestigationReportStatus {
  running
  completed
  failed

  @@map("investigation_report_status")
}

/// The shadow "investigation" agent's structured report for a snapshot. This, plus its child tables
/// (InvestigationFinding / InvestigationSuggestedTest), is the queryable native
/// home for the agent's output - it REPLACES the old S3-JSON round-trip (the API reads these tables and signs
/// the stored media keys on read). The whole set is an isolated island: it only FKs OUTWARD (snapshot / org,
/// cascade) and nothing in the core app FKs into it, so retiring the agent later is a clean DROP TABLE.
/// Internal-only surface (shown to @autonoma.app users to compare against the deployed diffs agent).
model InvestigationReport {
  snapshotId String         @id @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  /// Lifecycle for the progress UI: seeded `running` at workflow start, flipped `completed`/`failed` at the end.
  status         InvestigationReportStatus @default(completed) @map("status")
  /// Current workflow stage while running (progress UI); null once terminal or on legacy rows.
  stage          String?                   @map("stage")
  stageUpdatedAt DateTime?                  @map("stage_updated_at")

  /// Report header, denormalized so the read path never re-resolves PR meta (a heavy GitHub round-trip).
  client       String? @map("client")
  appSlug      String? @map("app_slug")
  prNumber     Int?    @map("pr_number")
  prTitle      String? @map("pr_title") @db.Text
  prBody       String? @map("pr_body") @db.Text
  repoFullName String? @map("repo_full_name")
  commitSha    String? @map("commit_sha")

  /// The deployed-agent comparison - a display-only blob, never queried, so JSON not a table.
  /// [InvestigationDeployedComparison]
  deployed Json? @map("deployed")

  /// Legacy S3 markdown key. Optional now: pre-cutover reports keep their raw-report link; new reports persist
  /// to the child tables and (per config) may still write the human-readable markdown mirror.
  s3Key          String? @map("s3_key")
  testCount      Int     @default(0) @map("test_count")
  clientBugCount Int     @default(0) @map("client_bug_count")

  findings       InvestigationFinding[]
  suggestedTests InvestigationSuggestedTest[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("investigation_report")
}

/// One classified per-test finding (the investigation agent's OWN classification - not the diffs Bug model).
/// Media stays as s3:// keys (signed on read); display-only blobs (evidence, run trace) are JSON; the fields
/// the UI filters/sorts on are real columns. FKs only to its parent report (cascade); organizationId is a
/// plain scalar for cross-report scoping, deliberately NOT a relation so the Organization model stays untouched.
model InvestigationFinding {
  id               String              @id @default(cuid())
  reportSnapshotId String              @map("report_snapshot_id")
  report           InvestigationReport @relation(fields: [reportSnapshotId], references: [snapshotId], onDelete: Cascade)

  /// Stable per-report routing id (the slug, suffixed when a slug appears more than once).
  findingKey        String  @map("finding_key")
  slug              String
  category          String
  confidence        String?
  planFidelity      String? @map("plan_fidelity")
  falsePositiveRisk String? @map("false_positive_risk")
  headline          String  @db.Text
  whatHappened      String? @map("what_happened") @db.Text
  observedAppIssues String? @map("observed_app_issues") @db.Text
  remediation       String? @db.Text
  rootCause         String? @map("root_cause") @db.Text
  suggestedFixDiff  String? @map("suggested_fix_diff") @db.Text
  plan              String? @db.Text
  runSuccess        Boolean? @map("run_success")
  stepCount         Int?     @map("step_count")

  /// string[] run trace and InvestigationEvidence[] - display blobs, never queried.
  /// [InvestigationRunSteps]
  runSteps Json? @map("run_steps")
  /// The structured, inspectable trace: per-step frame (s3 key, signed on read) + click coords. Additive/
  /// nullable; populated alongside runSteps, which stays the text fallback for legacy rows.
  /// [InvestigationRunTrace]
  runTrace Json? @map("run_trace")
  /// [InvestigationEvidenceList]
  evidence Json?

  /// s3:// keys, signed on read. screenshotKey is the error-frame once PR2 lands.
  videoKey      String? @map("video_key")
  screenshotKey String? @map("screenshot_key")

  /// Present instead of the verdict fields when the model failed to classify this test.
  error String? @db.Text

  /// When the reconciliation agent MERGED several tests that surfaced the same underlying issue into this one
  /// finding, the slugs of every test it now represents (this finding's own slug plus the absorbed ones). A
  /// merged finding carries the agent's combined narrative + the union of the members' evidence; the absorbed
  /// per-test findings are never persisted. Null/absent on a standalone (unreconciled) finding.
  /// [InvestigationCoveredSlugs]
  coveredSlugs Json? @map("covered_slugs")

  displayOrder Int @map("display_order")

  createdAt      DateTime @default(now()) @map("created_at")
  organizationId String   @map("organization_id")

  @@unique([reportSnapshotId, findingKey])
  @@index([reportSnapshotId])
  @@index([organizationId, category])
  @@map("investigation_finding")
}

/// A NEW test the agent proposes to add (with its validation outcome, if the validate->edit->retry loop ran).
model InvestigationSuggestedTest {
  id               String              @id @default(cuid())
  reportSnapshotId String              @map("report_snapshot_id")
  report           InvestigationReport @relation(fields: [reportSnapshotId], references: [snapshotId], onDelete: Cascade)

  name        String
  instruction String @db.Text
  reasoning   String @db.Text

  validationPassed        Boolean? @map("validation_passed")
  validationIterations    Int?     @map("validation_iterations")
  validationFailureReason String?  @map("validation_failure_reason") @db.Text

  displayOrder Int @map("display_order")

  createdAt      DateTime @default(now()) @map("created_at")
  organizationId String   @map("organization_id")

  @@index([reportSnapshotId])
  @@map("investigation_suggested_test")
}

model AffectedTest {
  snapshotId String   @map("snapshot_id")
  testCaseId String   @map("test_case_id")
  diffsJob   DiffsJob @relation(fields: [snapshotId], references: [snapshotId], onDelete: Cascade)
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  affectedReason AffectedReason @map("affected_reason")
  reasoning      String         @db.Text

  runId String? @unique @map("run_id")
  run   Run?    @relation(fields: [runId], references: [id], onDelete: SetNull)

  generationId String?         @unique @map("generation_id")
  generation   TestGeneration? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([snapshotId, testCaseId])
  @@map("affected_test")
}

// Generic durable fixed-window rate-limit counter. One row per limiter key (e.g.
// "onboarding-pair:<userId>"); `count` accumulates within the window that began
// at `windowStartedAt` and resets when the window elapses. Durable (in Postgres,
// not per-pod memory) so the limit holds across the API's replicas and pod
// restarts. Backs RateLimiterService. No TTL: rows persist after their window
// elapses, bounded by the number of distinct keys (user/app counts). If keys ever
// become high-cardinality, add a periodic prune of rows whose windowStartedAt is
// older than the max policy window.
model RateLimitCounter {
  key             String   @id
  windowStartedAt DateTime @map("window_started_at")
  count           Int      @default(0)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("rate_limit_counter")
}

