  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("github_installation")
}

// Stores GitHub ETags so we can make conditional requests (If-None-Match). An authorized
// 304 Not Modified does not count against the primary rate limit, making revalidation
// near-free. ETags are scoped per page URL and per installation token, so we key on
// (installationId, requestKey). We persist only the ETag, not the body: on a 304 nothing
// changed, so callers keep their existing Postgres cache.
model GitHubRequestEtag {
  installationId Int      @map("installation_id")
  requestKey     String   @map("request_key")
  etag           String
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@id([installationId, requestKey])
  @@map("github_request_etag")
}

