generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["tracing"]
}

datasource db {
  provider = "postgresql"
}

generator json {
  provider = "prisma-json-types-generator"
}

// ─── Better Auth Core Models ────────────────────────────────────────

enum UserRole {
  user
  admin

  @@map("user_role")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          UserRole @default(user)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions          Session[]
  accounts          Account[]
  members           Member[]
  invitations       Invitation[]       @relation("invitations")
  apiKeys           ApiKey[]
  applicationSetups ApplicationSetup[]
  signupHookStates  SignupHookState[]
  oauthApplications OauthApplication[]
  oauthAccessTokens OauthAccessToken[]
  oauthConsents     OauthConsent[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  activeOrganizationId String? @map("active_organization_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

// ─── Organization Plugin Models ─────────────────────────────────────

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  logo      String?
  metadata  String?
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  domain    String?            @unique
  status    OrganizationStatus @default(approved)

  members                Member[]
  invitations            Invitation[]
  apiKeys                ApiKey[]
  applications           Application[]
  branchDeployments      BranchDeployment[]
  webDeployments         WebDeployment[]
  mobileDeployments      MobileDeployment[]
  folders                Folder[]
  branches               Branch[]
  testCases              TestCase[]
  testPlans              TestPlan[]
  testGenerations        TestGeneration[]
  stepInputLists         StepInputList[]
  stepInputs             StepInput[]
  stepOutputLists        StepOutputList[]
  stepOutputs            StepOutput[]
  stepAttempts           StepAttempt[]
  tags                   Tag[]
  runs                   Run[]
  scenarios              Scenario[]
  scenarioRecipeVersions ScenarioRecipeVersion[]
  scenarioInstances      ScenarioInstance[]
  generationReviews      GenerationReview[]
  runReviews             RunReview[]
  issues                 Issue[]
  bugs                   Bug[]
  githubInstallation     GitHubInstallation?
  billingPricing         BillingPricing?
  settings               OrganizationSettings?
  promoRedemptions       BillingPromoRedemption[]
  billingCustomer        BillingCustomer?
  applicationSetups      ApplicationSetup[]
  signupHookStates       SignupHookState[]
  previewkitEnvironments PreviewkitEnvironment[]
  previewkitOrgSecrets   PreviewkitOrgSecret[]
  diffsJobs              DiffsJob[]
  investigationReports   InvestigationReport[]
  affectedTests          AffectedTest[]
  refinementLoops        RefinementLoop[]

  @@map("organization")
}

enum OnboardingStep {
  install
  configure
  working
  webhook_configuring
  discovering
  discovered
  dry_run_passed
  url
  github
  preview_environment
  previewkit_configuring
  previewkit_deploying
  existing_deploys_configuring
  existing_deploys_waiting
  preview_verified
  diff_trigger
  completed

  @@map("onboarding_step")
}

enum OnboardingPreviewEnvironmentMode {
  previewkit
  existing_deploys

  @@map("onboarding_preview_environment_mode")
}

enum OnboardingPreviewVerificationStatus {
  idle
  building
  ready
  failed

  @@map("onboarding_preview_verification_status")
}

model OnboardingState {
  id                        String                              @id @default(cuid())
  applicationId             String                              @unique @map("application_id")
  step                      OnboardingStep                      @default(github) @map("step")
  agentConnectedAt          DateTime?                           @map("agent_connected_at")
  /// [AgentLogs]
  agentLogs                 Json                                @default("[]") @map("agent_logs")
  productionUrl             String?                             @map("production_url")
  previewEnvironmentMode    OnboardingPreviewEnvironmentMode?   @map("preview_environment_mode")
  previewUrl                String?                             @map("preview_url")
  previewVerificationStatus OnboardingPreviewVerificationStatus @default(idle) @map("preview_verification_status")
  // When a previewkit main-branch deploy was last requested. This is the freshness
  // reference readiness uses to decide whether the environment reflects the current
  // deploy: `updatedAt` is bumped by unrelated writes (notably the agent heartbeat),
  // so comparing environment activity against it drifts past the ready moment and the
  // deploy is never observed as ready. This only changes when a deploy is requested.
  previewDeployRequestedAt  DateTime?                           @map("preview_deploy_requested_at")
  completedAt               DateTime?                           @map("completed_at")
  lastDiscoveryError        String?                             @map("last_discovery_error")
  lastDiscoveredAt          DateTime?                           @map("last_discovered_at")
  lastDiscoveredModels      Int?                                @map("last_discovered_models")
  discoveringStartedAt      DateTime?                           @map("discovering_started_at")
  // SDK dry-run succeeded (a capability tracked outside the linear `step` so it
  // can be (re)run from the Finish setup tab at any time, not just onboarding).
  dryRunPassedAt            DateTime?                           @map("dry_run_passed_at")
  // First real per-PR `deployment_status` observed. Backs the optimistic BYO
  // diff-trigger self-confirmation (Live is marked before this is set).
  diffTriggerConfirmedAt    DateTime?                           @map("diff_trigger_confirmed_at")

  // --- Agentic onboarding: a coding agent drives the previewkit config over MCP ---
  // Who currently drives the config. Default `human` (the user starts in the UI);
  // the agent's first claim is a deliberate human -> agent handoff, and Stop /
  // Take over flips it back. Agent-held => the UI is read-only. Distinct from
  // `agentConnectedAt` (mere presence): this is the soft mutex for who may write.
  agentHolder               OnboardingAgentHolder               @default(human) @map("agent_holder")
  // Heartbeat: refreshed on every agent tool call. The UI derives an idle release
  // (control handed back to the human) from `now - agentLastActivityAt` at read
  // time - no Redis, no background reaper.
  agentLastActivityAt       DateTime?                           @map("agent_last_activity_at")
  // A question only the human can answer, raised by the agent and rendered inline
  // in the locked UI (env values to enter, or a choice). Null when the agent is
  // not blocked. Secret VALUES never appear here - only the KEYS asked for.
  /// [OnboardingAgentPendingRequest]
  agentPendingRequest       Json?                               @map("agent_pending_request")
  // Short-lived, single-use pairing code shown in the UI so the user can hand the
  // agent this app without a mutable repo name: the agent presents it and we map
  // it to this app + org (already fixed here from the UI's authenticated context).
  agentPairingCode          String?                             @unique @map("agent_pairing_code")
  agentPairingExpiresAt     DateTime?                           @map("agent_pairing_expires_at")
  // Which coding agent is driving, from the MCP `clientInfo` handshake (e.g.
  // "claude-code", "cursor", "codex"). Best-effort - null when the client did not
  // report it - so the UI can name the agent ("Cursor is configuring...") instead
  // of hardcoding one, falling back to a neutral label when unknown.
  agentClient               String?                             @map("agent_client")

  createdAt                 DateTime                            @default(now()) @map("created_at")
  updatedAt                 DateTime                            @updatedAt @map("updated_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("onboarding_state")
}

enum OnboardingAgentHolder {
  human
  agent

  @@map("onboarding_agent_holder")
}

// ─── Application Setup ──────────────────────────────────────────────

model ApplicationSetup {
  id           String    @id @default(cuid())
  name         String?
  status       String    @default("running")
  currentStep  Int       @default(0) @map("current_step")
  totalSteps   Int       @default(5) @map("total_steps")
  errorMessage String?   @map("error_message")
  completedAt  DateTime? @map("completed_at")

  applicationId  String       @map("application_id")
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  events ApplicationSetupEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([applicationId])
  @@index([organizationId])
  @@map("application_setup")
}

model ApplicationSetupEvent {
  id        String           @id @default(cuid())
  type      String
  data      Json             @default("{}")
  setupId   String           @map("setup_id")
  setup     ApplicationSetup @relation(fields: [setupId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([setupId])
  @@map("application_setup_event")
}

model Member {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("member")
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  inviterId      String   @map("inviter_id")
  organizationId String   @map("organization_id")
  role           String
  status         String   @default("pending")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  inviter      User         @relation("invitations", fields: [inviterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model SignupHookState {
  id             String @id @default(cuid())
  userId         String @map("user_id")
  organizationId String @map("organization_id")

  newsletterAddedAt         DateTime? @map("newsletter_added_at")
  defaultWelcomeEmailSentAt DateTime? @map("default_welcome_email_sent_at")
  premiumWelcomeEmailSentAt DateTime? @map("premium_welcome_email_sent_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("signup_hook_state")
}

// --- Application Models ─────────────────────────────────────────────

enum ApplicationArchitecture {
  WEB
  IOS
  ANDROID

  @@map("application_architecture")
}

model Application {
  id                      String                  @id @default(cuid())
  name                    String
  slug                    String                  @map("slug")
  architecture            ApplicationArchitecture
  customInstructions      String?                 @map("custom_instructions")
  testScopeGuidelines     String?                 @map("test_scope_guidelines")
  disabled                Boolean                 @default(false)
  githubRepositoryId      Int?                    @map("github_repository_id")

  mainBranchId String? @unique @map("main_branch_id")
  mainBranch   Branch? @relation("MainBranch", fields: [mainBranchId], references: [id])

  signingSecretEnc String? @map("signing_secret_enc")

  folders                 Folder[]
  testCases               TestCase[]
  tags                    Tag[]
  scenarios               Scenario[]
  scenarioSchemaSnapshots ScenarioSchemaSnapshot[]
  scenarioRecipeVersions  ScenarioRecipeVersion[]
  scenarioInstances       ScenarioInstance[]
  webhookCalls            WebhookCall[]
  branches                Branch[]
  featureBranchInfos      FeatureBranchInfo[]
  mainBranchInfo          MainBranchInfo?
  onboardingState         OnboardingState?
  applicationSetups       ApplicationSetup[]
  bugs                      Bug[]
  previewkitSecrets         PreviewkitSecret[]

  // The Application's preview config (latest-only; saving overwrites it in
  // place). No row means the Application has no preview config and its
  // previews are skipped (opt-out) rather than erroring. This is the config the
  // deploy pipeline reads.
  previewkitConfig PreviewkitConfig?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([name, organizationId])
  @@unique([slug, organizationId])
  @@unique([organizationId, githubRepositoryId])
  @@map("application")
}

// ─── Branch Deployment ────────────────────────────────────────────────────────

model BranchDeployment {
  id     String  @id @default(cuid())
  active Boolean @default(true)

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  webhookUrl     String? @map("webhook_url")
  /// ![Record<string, string>]
  webhookHeaders Json?   @map("webhook_headers")

  activeOnBranch    Branch?            @relation("ActiveDeployment")
  scenarioInstances ScenarioInstance[]
  webDeployment     WebDeployment?
  mobileDeployment  MobileDeployment?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@map("branch_deployment")
}

model WebDeployment {
  deploymentId String           @map("deployment_id")
  deployment   BranchDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  url  String
  file String

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([deploymentId])
  @@map("web_deployment")
}

model MobileDeployment {
  deploymentId String           @map("deployment_id")
  deployment   BranchDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  packageUrl  String @map("package_url")
  photo       String @map("photo")
  packageName String @map("package_name")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([deploymentId])
  @@map("mobile_deployment")
}

// ─── API Key Plugin Model ───────────────────────────────────────────

model ApiKey {
  id                  String    @id @default(cuid())
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String    @map("user_id")
  organizationId      String    @map("organization_id")
  refillInterval      Int?      @map("refill_interval")
  refillAmount        Int?      @map("refill_amount")
  lastRefillAt        DateTime? @map("last_refill_at")
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(false) @map("rate_limit_enabled")
  rateLimitTimeWindow Int?      @map("rate_limit_time_window")
  rateLimitMax        Int?      @map("rate_limit_max")
  requestCount        Int       @default(0) @map("request_count")
  remaining           Int?
  lastRequest         DateTime? @map("last_request")
  expiresAt           DateTime? @map("expires_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  permissions         String?
  metadata            String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("api_key")
}

// ─── Better Auth: MCP OAuth (jwt + mcp/oidc-provider plugins) ───────
// Backing tables for the `jwt()` and `mcp()` plugins in apps/api/src/auth.ts.
// The jwt plugin signs a JWT on every session response, so `Jwks` is read on
// normal app operation, not only the MCP OAuth path. Field names mirror
// better-auth's plugin schema exactly (it queries by Prisma field name); the
// snake_case columns are transparent to it.

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String    @map("public_key")
  privateKey String    @map("private_key")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  @@map("jwks")
}

model OauthApplication {
  id           String   @id @default(cuid())
  name         String
  icon         String?
  metadata     String?
  clientId     String   @unique @map("client_id")
  clientSecret String?  @map("client_secret")
  redirectUrls String   @map("redirect_urls")
  type         String
  disabled     Boolean? @default(false)
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessTokens OauthAccessToken[]
  consents     OauthConsent[]

  @@index([userId])
  @@map("oauth_application")
}

model OauthAccessToken {
  id                    String   @id @default(cuid())
  accessToken           String   @unique @map("access_token")
  refreshToken          String   @unique @map("refresh_token")
  accessTokenExpiresAt  DateTime @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime @map("refresh_token_expires_at")
  clientId              String   @map("client_id")
  userId                String?  @map("user_id")
  scopes                String
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  application OauthApplication @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@map("oauth_access_token")
}

model OauthConsent {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  userId       String   @map("user_id")
  scopes       String
  consentGiven Boolean  @map("consent_given")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  application OauthApplication @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@map("oauth_consent")
}

// ─── Enums ─────────────────────────────────────────────────────────

enum OrganizationStatus {
  pending
  approved
  rejected

  @@map("organization_status")
}

// ─── Organization & Test Structure ─────────────────────────────────

model Folder {
  id            String      @id @default(cuid())
  name          String
  description   String?
  applicationId String      @map("application_id")
  parentId      String?     @map("parent_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parent        Folder?     @relation("FolderTree", fields: [parentId], references: [id])
  children      Folder[]    @relation("FolderTree")
  testCases     TestCase[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, parentId, name])
  @@map("folder")
}

// ─── Branch & Versioning ──────────────────────────────────────────────────────

model Branch {
  id   String @id @default(cuid())
  name String

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  deploymentId String?           @unique @map("deployment_id")
  deployment   BranchDeployment? @relation("ActiveDeployment", fields: [deploymentId], references: [id])

  activeSnapshotId  String?         @unique @map("active_snapshot_id")
  activeSnapshot    BranchSnapshot? @relation("ActiveSnapshot", fields: [activeSnapshotId], references: [id])
  pendingSnapshotId String?         @unique @map("pending_snapshot_id")
  pendingSnapshot   BranchSnapshot? @relation("PendingSnapshot", fields: [pendingSnapshotId], references: [id])
  baseSnapshotId    String?         @map("base_snapshot_id")
  baseSnapshot      BranchSnapshot? @relation("BaseSnapshot", fields: [baseSnapshotId], references: [id])

  mainOfApplication Application?       @relation("MainBranch")
  snapshots         BranchSnapshot[]
  deployments       BranchDeployment[]
  bugs              Bug[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  prInfo   FeatureBranchInfo?
  mainInfo MainBranchInfo?

  previewkitEnvironment PreviewkitEnvironment?

  @@map("branch")
}

enum PullRequestCacheState {
  open
  closed
  merged

  @@map("pull_request_cache_state")
}

model FeatureBranchInfo {
  branchId      String @id @map("branch_id")
  applicationId String @map("application_id")
  prNumber      Int    @map("pr_number")

  // Cached PR metadata (best-effort; filled by GitHub webhooks + the polite revalidate).
  // All nullable: an empty cache is valid and is backfilled lazily.
  prTitle       String?                @map("pr_title")
  prState       PullRequestCacheState? @map("pr_state")
  prAuthorLogin String?                @map("pr_author_login")
  prUpdatedAt   DateTime?              @map("pr_updated_at") // GitHub's updated_at (drives the "Updated" column)
  prCachedAt    DateTime?              @map("pr_cached_at") // our last write time (drives the freshness/throttle gate)

  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, prNumber])
  @@index([applicationId, prCachedAt])
  @@map("feature_branch_info")
}

model MainBranchInfo {
  branchId      String @id @map("branch_id")
  applicationId String @unique @map("application_id")
  githubRef     String @map("github_ref")

  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("main_branch_info")
}

enum TriggerSource {
  GITHUB_PUSH
  MANUAL
  WEBHOOK

  @@map("trigger_source")
}

enum SnapshotStatus {
  processing
  active
  superseded
  failed
  cancelled

  @@map("snapshot_status")
}

model BranchSnapshot {
  id        String         @id @default(cuid())
  status    SnapshotStatus @default(processing)
  createdAt DateTime       @default(now()) @map("created_at")

  branchId String @map("branch_id")
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  source  TriggerSource
  headSha String?       @map("head_sha")
  baseSha String?       @map("base_sha")
  /// [JsonValue]
  payload Json?

  prevSnapshotId String?          @map("prev_snapshot_id")
  prevSnapshot   BranchSnapshot?  @relation("SnapshotHistory", fields: [prevSnapshotId], references: [id])
  nextSnapshots  BranchSnapshot[] @relation("SnapshotHistory")

  // The detached investigation twin paired with this snapshot, if any. The
  // investigation agent runs on its own snapshot so its shadow generations never
  // pollute this snapshot's pending-generation set (which the refinement loop
  // reads). The twin is never wired to a branch pointer; it is reachable only via
  // this FK. `investigationParent` (the reverse side) is the canonical signal that
  // a snapshot IS such a twin, used to hide it from user-facing snapshot queries.
  investigationSnapshotId String?         @unique @map("investigation_snapshot_id")
  investigationSnapshot   BranchSnapshot? @relation("InvestigationPair", fields: [investigationSnapshotId], references: [id], onDelete: SetNull)
  investigationParent     BranchSnapshot? @relation("InvestigationPair")

  // Per-dependency deployed commit SHAs (keyed by previewkit multirepo dependency
  // name), pinned the first time grounding runs for this snapshot by resolving the
  // headSha-exact PreviewkitEnvironment and copying its enriched resolvedConfig dep
  // SHAs. All agents in the snapshot read this pinned copy so a later redeploy can
  // not corrupt an in-flight snapshot's multi-repo fidelity. `null` = not yet
  // pinned; `{}` = pinned with no matching/partial manifest (degrade, never error).
  /// ![Record<string, string>]
  pinnedDependencyShas Json? @map("pinned_dependency_shas")

  testCaseAssignments     TestCaseAssignment[]
  scenarioSchemaSnapshots ScenarioSchemaSnapshot[]
  scenarioRecipeVersions  ScenarioRecipeVersion[]

  activeOnBranch  Branch?          @relation("ActiveSnapshot")
  pendingOnBranch Branch?          @relation("PendingSnapshot")
  baseOfBranches  Branch[]         @relation("BaseSnapshot")
  testGenerations TestGeneration[]

  diffsJob             DiffsJob?
  investigationReport  InvestigationReport?
  investigationAiCosts AiCostRecord[]       @relation("InvestigationAiCost")
  issues               Issue[]
  refinementLoop       RefinementLoop?

  @@index([branchId])
  @@map("branch_snapshot")
}

model TestCaseAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  snapshotId String         @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  planId  String?        @map("plan_id")
  plan    TestPlan?      @relation(fields: [planId], references: [id])
  stepsId String?        @map("steps_id")
  steps   StepInputList? @relation(fields: [stepsId], references: [id])

  // DEPRECATED / UNUSED. The quarantine skip was removed: reported tests now
  // re-run every snapshot instead of being excluded via this flag. No code reads
  // or writes this column anymore. It is kept nullable and abandoned in place (no
  // DROP COLUMN) so existing rows and the foreign key stay untouched.
  quarantineIssueId String? @map("quarantine_issue_id")
  quarantineIssue   Issue?  @relation(fields: [quarantineIssueId], references: [id], onDelete: SetNull)

  runs Run[]

  @@unique([snapshotId, testCaseId])
  @@map("test_case_assignment")
}

// ─── Test Case ────────────────────────────────────────────────────────────────

model TestCase {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String?

  /// A throwaway test case created by the investigation agent ONLY to validate a proposed NEW test (run its
  /// candidate plan as a shadow generation). Shadow cases are never assigned to a snapshot and are excluded from
  /// every user-facing catalog read, so they never pollute the customer's test tree. Mirrors TestGeneration.shadow.
  shadow Boolean @default(false) @map("shadow")

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  folderId String @map("folder_id")
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  plans       TestPlan[]
  tags        TestTag[]
  assignments TestCaseAssignment[]

  bugEvidence BugTestCaseEvidence[]

  affectedIn AffectedTest[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, slug])
  @@map("test_case")
}

// ─── Test Generation ───────────────────────────────────────────────────────────

model TestPlan {
  id String @id @default(cuid())

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  prompt       String
  scenarioId   String?   @map("scenario_id")
  scenario     Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  scenarioName String?   @map("scenario_name")

  generations               TestGeneration[]
  stepLists                 StepInputList[]
  assignments               TestCaseAssignment[]
  runs                      Run[]
  refinementIterationInputs RefinementIterationInput[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([testCaseId])
  @@map("test_plan")
}

enum GenerationStatus {
  pending
  queued
  running
  success
  failed

  @@map("generation_status")
}

model TestGeneration {
  id         String @id @default(cuid())
  testPlanId String @map("test_plan_id")

  status          GenerationStatus @default(pending)
  reasoning       String?          @map("reasoning")
  finalScreenshot String?          @map("final_screenshot")
  videoUrl        String?          @map("video_url")

  /// A shadow generation created by the investigation agent (not a real user/diffs generation). Shadow rows
  /// are excluded from every user-facing generation view and from the refinement loop's per-test-case dedup,
  /// so orphaned `pending` shadow rows (the investigation workflow can stop mid-run) never pollute the
  /// customer's UI or trip the "one plan per test case" invariant.
  shadow Boolean @default(false) @map("shadow")

  /// Structured failure detail. Set iff status == failed (for rows created
  /// after this column existed; historical failed rows have null). System
  /// failures (scenario_setup, engine_error) carry a message and render in the
  /// critical failure panel; agent_failed/max_steps render via the agent UI.
  /// [GenerationFailure]
  failure Json? @map("failure")

  snapshotId String         @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Restrict)

  /// [ModelConversation]
  conversation Json @default("[]")

  /// S3 URL where the full conversation JSON is stored
  conversationUrl String? @map("conversation_url")

  /// Extracted variables from the agent's memory system
  memory Json @default("{}") @map("memory")

  testPlan         TestPlan          @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  costRecords      AiCostRecord[]
  generationReview GenerationReview?
  attempts         StepAttempt[]

  affectedTest AffectedTest?

  scenarioInstanceId String?           @map("scenario_instance_id")
  scenarioInstance   ScenarioInstance? @relation(fields: [scenarioInstanceId], references: [id], onDelete: SetNull)

  stepsId   String?         @map("steps_id")
  steps     StepInputList?  @relation(fields: [stepsId], references: [id])
  outputsId String?         @unique @map("outputs_id")
  outputs   StepOutputList? @relation(fields: [outputsId], references: [id])

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@map("test_generation")
}

// ─── Generation Review ───────────────────────────────────────────────────────

enum GenerationReviewVerdict {
  success
  agent_limitation
  application_bug
  plan_mismatch
  unknown_issue
  scenario_unsupported

  @@map("generation_review_verdict")
}

enum RunReviewVerdict {
  engine_error
  application_bug
  unknown_issue

  @@map("run_review_verdict")
}

enum ReviewStatus {
  pending
  completed
  failed

  @@map("review_status")
}

model GenerationReview {
  id           String         @id @default(cuid())
  generationId String         @unique @map("generation_id")
  generation   TestGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  status    ReviewStatus             @default(pending)
  verdict   GenerationReviewVerdict?
  reasoning String?                  @db.Text
  analysis  Json                     @default("{}")
  issue     Issue?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("generation_review")
}

model RunReview {
  id    String @id @default(cuid())
  runId String @unique @map("run_id")
  run   Run    @relation(fields: [runId], references: [id], onDelete: Cascade)

  status    ReviewStatus      @default(pending)
  verdict   RunReviewVerdict?
  reasoning String?           @db.Text
  analysis  Json              @default("{}")
  issue     Issue?

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("run_review")
}

// ─── Issue ───────────────────────────────────────────────────────────────────

enum IssueSeverity {
  critical
  high
  medium
  low

  @@map("issue_severity")
}

enum IssueKind {
  application_bug
  engine_limitation
  unknown_issue
  scenario_unsupported

  @@map("issue_kind")
}

model Issue {
  id                 String            @id @default(cuid())
  generationReviewId String?           @unique @map("review_id")
  generationReview   GenerationReview? @relation(fields: [generationReviewId], references: [id], onDelete: Cascade)
  runReviewId        String?           @unique @map("run_review_id")
  runReview          RunReview?        @relation(fields: [runReviewId], references: [id], onDelete: Cascade)

  kind        IssueKind     @default(application_bug)
  severity    IssueSeverity
  title       String
  description String        @db.Text
  dismissed   Boolean       @default(false)

  // The healing-authored, evidence-grounded customer-facing report for this
  // occurrence (Expected/Actual + narrative). Null when no report was authored.
  /// [IssueReport]
  report Json?

  // Set for the Bug-less, snapshot-scoped kinds (engine_limitation, unknown_issue,
  // scenario_unsupported): none aggregates into a customer-facing Bug, so each lives
  // with its snapshot.
  snapshotId String?         @map("snapshot_id")
  snapshot   BranchSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  bugId String? @map("bug_id")
  bug   Bug?    @relation(fields: [bugId], references: [id], onDelete: SetNull)

  quarantinedAssignments TestCaseAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([bugId])
  @@map("issue")
}

// ─── Bug ─────────────────────────────────────────────────────────────────────

enum BugStatus {
  open
  resolved
  regressed

  @@map("bug_status")
}

model Bug {
  id          String        @id @default(cuid())
  status      BugStatus     @default(open)
  title       String
  description String        @db.Text
  severity    IssueSeverity

  applicationId String      @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // The branch this bug is scoped to, derived from the snapshot it was detected on.
  // Nullable during the additive migration: pre-existing bugs keep branchId = null
  // (abandoned by branch-scoped reads). New bugs always stamp it. The denormalized
  // applicationId is retained so application-scoped reads keep working.
  branchId String? @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Cascade)

  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  resolvedAt  DateTime? @map("resolved_at")

  evidence BugTestCaseEvidence[]
  issues   Issue[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([applicationId, lastSeenAt])
  @@index([status])
  @@index([branchId, status])
  @@index([branchId, lastSeenAt])
  @@map("bug")
}

model BugTestCaseEvidence {
  id String @id @default(cuid())

  bugId String @map("bug_id")
  bug   Bug    @relation(fields: [bugId], references: [id], onDelete: Cascade)

  testCaseId String   @map("test_case_id")
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")

  @@unique([bugId, testCaseId])
  @@index([testCaseId])
  @@map("bug_test_case_evidence")
}

// ─── Refinement Loop ─────────────────────────────────────────────────────────

enum RefinementTrigger {
  onboarding
  diffs

  @@map("refinement_trigger")
}

enum RefinementStatus {
  running
  converged
  max_iterations
  error

  @@map("refinement_status")
}

enum RefinementActionKind {
  update_plan
  add_test
  report_bug
  report_engine_limitation
  report_unknown_issue
  report_scenario_unsupported
  remove_test

  @@map("refinement_action_kind")
}

enum RefinementIterationStatus {
  pending
  running
  completed

  @@map("refinement_iteration_status")
}

model RefinementLoop {
  id String @id @default(cuid())

  snapshotId String         @unique @map("snapshot_id")
  snapshot   BranchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  triggeredBy RefinementTrigger @map("triggered_by")
  status      RefinementStatus  @default(running)

  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  iterations RefinementIteration[]

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("refinement_loop")
}

model RefinementIteration {
  id String @id @default(cuid())

  loopId String         @map("loop_id")
  loop   RefinementLoop @relation(fields: [loopId], references: [id], onDelete: Cascade)

  number     Int
  status     RefinementIterationStatus @default(pending)
  startedAt  DateTime                  @default(now()) @map("started_at")
  finishedAt DateTime?                 @map("finished_at")

  /// S3 URL of the persisted HealingAgent conversation for this iteration.
  healingConversationUrl String? @map("healing_conversation_url")

  /// The HealingAgent's one-paragraph summary reasoning for this iteration,
  /// captured from its finish tool. Nullable: written after the agent runs, so
  /// it stays null for pending/running iterations and for iterations that error
  /// before the agent finishes.
  reasoning String? @map("reasoning") @db.Text

  actions RefinementAction[]
  inputs  RefinementIterationInput[]

  @@unique([loopId, number])
  @@map("refinement_iteration")
}

model RefinementAction {
  id String @id @default(cuid())

  iterationId String              @map("iteration_id")
  iteration   RefinementIteration @relation(fields: [iterationId], references: [id], onDelete: Cascade)

  planId     String?              @map("plan_id")
  testCaseId String?              @map("test_case_id")
  kind       RefinementActionKind

  /// ![object]
  payload   Json
  reasoning String @db.Text

  appliedAt DateTime? @map("applied_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([iterationId])
  @@map("refinement_action")
}

/// The set of plans each refinement iteration is responsible for analyzing.
/// Iter 1's rows are written by the loop's init from the seed planIds parameter;
/// iter N+1's rows are written by applyHealingActions when plan-changing actions
/// (update_plan, add_test) are produced. Makes the loop's scope an explicit
/// first-class fact rather than an inferred join over upstream tables.
model RefinementIterationInput {
  iterationId String   @map("iteration_id")
  planId      String   @map("plan_id")
  createdAt   DateTime @default(now()) @map("created_at")

  iteration RefinementIteration @relation(fields: [iterationId], references: [id], onDelete: Cascade)
  plan      TestPlan            @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([iterationId, planId])
  @@index([iterationId])
  @@map("refinement_iteration_input")
}

// ─── Step Input / Output ──────────────────────────────────────────────────────

model StepInputList {
  id   String      @id @default(cuid())
  list StepInput[]

  planId String   @map("plan_id")
  plan   TestPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  generations TestGeneration[]
  assignments TestCaseAssignment[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("step_input_list")
}

model StepInput {
  id     String @id @default(cuid())
  listId String @map("list_id")
  order  Int

  interaction   String
  /// ![object]
  params        Json
  waitCondition String? @map("wait_condition")

  screenshotBefore String? @map("screenshot_before")
  screenshotAfter  String? @map("screenshot_after")

  list    StepInputList @relation(fields: [listId], references: [id], onDelete: Cascade)
  outputs StepOutput[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([listId, order])
  @@index([listId])
  @@map("step_input")
}

model StepOutputList {
  id   String       @id @default(cuid())
  list StepOutput[]

  generation TestGeneration?

  runId String? @unique @map("run_id")
  run   Run?    @relation(fields: [runId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("step_output_list")
}

model StepOutput {
  id     String @id @default(cuid())
  listId String @map("list_id")
  order  Int

  /// ![object]
  output Json

  stepInputId String    @map("step_input_id")
  stepInput   StepInput @relation(fields: [stepInputId], references: [id], onDelete: Cascade)

  screenshotBefore String? @map("screenshot_before")
  screenshotAfter  String? @map("screenshot_after")

  list StepOutputList @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([listId, order])
  @@index([listId])
  @@map("step_output")
}

enum StepAttemptStatus {
  success
  failed

  @@map("step_attempt_status")
}

// Records every command attempt a generation makes - successes and failures
// alike - capturing the full attempt timeline. Unlike StepInput (the
// successful-only replay list), StepAttempt.order counts failures too. There is
// intentionally no FK linking a StepAttempt to its corresponding StepInput.
model StepAttempt {
  id    String @id @default(cuid())
  // Position in the full attempt timeline, counting failures.
  order Int

  interaction String
  // Command params, as provided to the command. Absent if param extraction threw.
  /// ![object]
  params      Json?

  status StepAttemptStatus

  // Command result, present on success.
  /// ![object]
  output    Json?
  // error.message, present on failure.
  error     String?
  // error class name, present on failure (attribution signal).
  errorName String? @map("error_name")

  screenshotBefore String? @map("screenshot_before")
  screenshotAfter  String? @map("screenshot_after")

  generationId String         @map("generation_id")
  generation   TestGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([generationId, order])
  @@index([generationId])
  @@map("step_attempt")
}

// ─── Tag ──────────────────────────────────────────────────────────────────────

model Tag {
  id            String @id @default(cuid())
  name          String
  color         String
  applicationId String @map("application_id")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  testTags    TestTag[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tag")
}

model TestTag {
  id         String @id @default(cuid())
  testCaseId String @map("test_case_id")
  tagId      String @map("tag_id")

  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([testCaseId, tagId])
  @@map("test_tag")
}

// ─── AI Cost Tracking ─────────────────────────────────────────────

model AiCostRecord {
  id                      String   @id @default(cuid())
  generationId            String?  @map("generation_id")
  runId                   String?  @map("run_id")
  investigationSnapshotId String?  @map("investigation_snapshot_id")
  model                   String
  tag                     String
  inputTokens             Int      @map("input_tokens")
  outputTokens            Int      @map("output_tokens")
  reasoningTokens         Int      @default(0) @map("reasoning_tokens")
  cacheReadTokens         Int      @default(0) @map("cache_read_tokens")
  costMicrodollars        Int      @map("cost_microdollars")
  createdAt               DateTime @default(now()) @map("created_at")

  generation TestGeneration? @relation(fields: [generationId], references: [id], onDelete: Cascade)
  run        Run?            @relation(fields: [runId], references: [id], onDelete: Cascade)

  // Orchestration LLM spend for an investigation, keyed on its (detached) snapshot.
  // Set for the investigation workflow's select/classify/diagnose/merge calls, which
  // are tied to neither a user generation nor a run.
  investigationSnapshot BranchSnapshot? @relation("InvestigationAiCost", fields: [investigationSnapshotId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([runId])
  @@index([investigationSnapshotId])
  @@map("ai_cost_record")
}

// ─── Run Execution ─────────────────────────────────────────────────

enum RunStatus {
  pending
  running
  success
  failed

  @@map("run_status")
}

model Run {
  id          String    @id @default(cuid())
  status      RunStatus @default(pending)
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  assignmentId String             @map("assignment_id")
  assignment   TestCaseAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  /// Snapshot of the plan this run executed. Captured at run creation time so it
  /// survives later mutations to TestCaseAssignment.planId via updatePlan.
  planId String?   @map("plan_id")
  plan   TestPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  scenarioInstanceId String?           @map("scenario_instance_id")
  scenarioInstance   ScenarioInstance? @relation(fields: [scenarioInstanceId], references: [id], onDelete: SetNull)

  outputs     StepOutputList?
  runReview   RunReview?
  costRecords AiCostRecord[]

  affectedTest AffectedTest?

  reasoning String? @map("reasoning") @db.Text

  /// Structured failure detail. Set iff status == failed (for rows created
  /// after this column existed; historical failed rows have null). System
  /// failures (scenario_setup, engine_error) carry a message and render in the
  /// critical failure panel; replay_failed renders via the agent UI.
  /// [RunFailure]
  failure Json? @map("failure")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([planId])
  @@map("run")
}

// ─── Scenario Setup/Teardown ──────────────────────────────────────

enum ScenarioInstanceStatus {
  REQUESTED
  UP_SUCCESS
  UP_FAILED
  RUNNING_TESTS
  DOWN_SUCCESS
  DOWN_FAILED

  @@map("scenario_instance_status")
}

enum WebhookAction {
  DISCOVER
  UP
  DOWN

  @@map("webhook_action")
}

model Scenario {
  id                    String  @id @default(cuid())
  applicationId         String  @map("application_id")
  name                  String
  description           String?
  activeRecipeVersionId String? @unique @map("active_recipe_version_id")

  lastSeenFingerprint  String?   @map("last_seen_fingerprint")
  lastDiscoveredAt     DateTime? @map("last_discovered_at")
  fingerprintChangedAt DateTime? @map("fingerprint_changed_at")
  isDisabled           Boolean   @default(false) @map("is_disabled")

  application         Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  activeRecipeVersion ScenarioRecipeVersion?  @relation("ActiveScenarioRecipeVersion", fields: [activeRecipeVersionId], references: [id], onDelete: SetNull)
  recipeVersions      ScenarioRecipeVersion[] @relation("ScenarioRecipeVersionHistory")
  instances           ScenarioInstance[]
  testPlans           TestPlan[]

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, name])
  @@map("scenario")
}

model ScenarioSchemaSnapshot {
  id            String @id @default(cuid())
  applicationId String @map("application_id")
  snapshotId    String @map("snapshot_id")
  /// [ScenarioStructureJson]
