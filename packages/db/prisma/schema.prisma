  application    Application             @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  snapshot       BranchSnapshot          @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  recipeVersions ScenarioRecipeVersion[]

