  // still runs for every org via INVESTIGATION_SHADOW_ENABLED; only the mutating steps are gated here so we can
  // roll autofix out per trusted org (Centinel first) before enabling it broadly.
  investigationAutofixEnabled Boolean @default(false) @map("investigation_autofix_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

