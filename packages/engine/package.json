{
    "name": "@autonoma/engine",
    "version": "0.0.1",
    "private": true,
    "description": "Core engine for the Autonoma testing platform",
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./command-defs": "./src/commands/command-defs.ts"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "eval": "vitest run --config vitest.eval.config.ts --passWithNoTests"
    },
    "dependencies": {
        "@11ty/gray-matter": "^2.1.0",
        "@autonoma/ai": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/errors": "workspace:*",
        "@autonoma/image": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@autonoma/integration-test": "workspace:*",
        "@testcontainers/postgresql": "^11.12.0",
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
