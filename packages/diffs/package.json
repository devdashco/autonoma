{
    "name": "@autonoma/diffs",
    "version": "1.0.0",
    "type": "module",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./env": "./src/env.ts",
        "./prepare-runs": "./src/callbacks/trigger-tests.ts",
        "./run-diffs-locally": "./src/run-diffs-locally.ts",
        "./run-resolution-locally": "./src/run-resolution-locally.ts"
    },
    "scripts": {
        "test": "vitest",
        "eval": "RUN_EVALS=true vitest",
        "lint-files": "oxlint --fix",
        "lint": "pnpm lint-files .",
        "fmt": "oxfmt --write src/",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "local-diff-analysis": "tsx --env-file=../../.env scripts/local-diff-analysis.ts",
        "local-resolution": "tsx --env-file=../../.env scripts/local-resolution.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/billing": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/test-updates": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@autonoma/workflow": "workspace:*",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "glob": "^11.1.0",
        "rimraf": "^6.1.3",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@autonoma/integration-test": "workspace:*",
        "@testcontainers/postgresql": "^11.12.0",
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
