generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BenchmarkBatchStatus {
  running
  completed

  @@map("benchmark_batch_status")
}

enum BenchmarkGenerationStatus {
  pending
  running
  success
  failed

  @@map("benchmark_generation_status")
}

model BenchmarkBatch {
  id          String               @id @default(cuid())
  status      BenchmarkBatchStatus @default(running)
  repeatCount Int                  @map("repeat_count")
  appUrls     String[]             @map("app_urls")
  createdAt   DateTime             @default(now()) @map("created_at")
  completedAt DateTime?            @map("completed_at")

  generations BenchmarkGeneration[]
  metrics     GenerationMetric[]
  runs        BenchmarkRun[]

  @@map("benchmark_batch")
}

model BenchmarkGeneration {
  id               String                    @id @default(cuid())
  batchId          String                    @map("batch_id")
  testPlanId       String                    @map("test_plan_id")
  testGenerationId String                    @map("test_generation_id")
  appUrl           String                    @map("app_url")
  status           BenchmarkGenerationStatus @default(pending)
  verdict          String?
  verdictReasoning String?                   @map("verdict_reasoning")
  stepCount        Int?                      @map("step_count")
  createdAt        DateTime                  @default(now()) @map("created_at")
  completedAt      DateTime?                 @map("completed_at")

  batch BenchmarkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([testGenerationId])
  @@map("benchmark_generation")
}

model GenerationMetric {
  id               String   @id @default(cuid())
  batchId          String   @map("batch_id")
  testGenerationId String   @map("test_generation_id")
  passed           Boolean
  createdAt        DateTime @default(now()) @map("created_at")

  batch BenchmarkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([testGenerationId])
  @@map("generation_metric")
}

model BenchmarkRun {
  id    String                    @id @default(cuid())
  batchId  String                 @map("batch_id")
  testPlanId String               @map("test_plan_id")
  runId    String                 @map("run_id")
  org      String
  status   BenchmarkGenerationStatus @default(pending)
  verdict          String?
  verdictReasoning String?  @map("verdict_reasoning")
  createdAt        DateTime @default(now()) @map("created_at")
  completedAt      DateTime? @map("completed_at")

  batch BenchmarkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([runId])
  @@map("benchmark_run")
}
