{
    "name": "@autonoma/review",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./env": "./src/env.ts"
    },
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --passWithNoTests",
        "review:generation": "tsx --env-file=../../.env src/generation/run-generation-review.ts",
        "review:replay": "tsx --env-file=../../.env src/replay/run-replay-review.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/codebase": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@google/genai": "^1.42.0",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
