{
    "name": "@autonoma/api",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        "./router": {
            "types": "./src/routes/router.ts"
        }
    },
    "scripts": {
        "dev": "tsx watch --env-file=../../.env src/index.ts",
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint --fix src/",
        "fmt": "oxfmt --write src/",
        "test": "vitest run --config vitest.config.ts --passWithNoTests",
        "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
        "test:all": "vitest run --config vitest.config.ts --passWithNoTests & vitest run --config vitest.integration.config.ts --passWithNoTests & wait",
        "agent:execute": "tsx --env-file=../../.env src/scripts/batch-generate.ts",
        "migrate:preview-config-secrets": "tsx --env-file=../../.env src/scripts/migrate-preview-config-secrets.ts"
    },
    "dependencies": {
        "@ai-sdk/google": "catalog:",
        "@autonoma/analytics": "workspace:*",
        "@autonoma/auth": "workspace:*",
        "@autonoma/billing": "workspace:*",
        "@autonoma/checkpoint": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/errors": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/investigation": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/scenario": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/test-updates": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@autonoma/utils": "workspace:*",
        "@autonoma/workflow": "workspace:*",
        "@aws-sdk/client-secrets-manager": "^3.1045.0",
        "@better-auth/api-key": "catalog:",
        "@better-auth/redis-storage": "^1.6.14",
        "@hono/node-server": "^1.19.14",
        "@kubernetes/client-node": "catalog:",
        "@octokit/app": "^16.1.2",
        "@octokit/webhooks": "^14.2.0",
        "@sentry/node": "catalog:",
        "@slack/web-api": "^7.15.0",
        "@t3-oss/env-core": "catalog:",
        "@trpc/server": "catalog:",
        "ai": "catalog:",
        "better-auth": "catalog:",
        "dotenv": "catalog:",
        "hono": "catalog:",
        "ioredis": "^5.9.3",
        "js-yaml": "^4.1.2",
        "prom-client": "catalog:",
        "resend": "^6.10.0",
        "superjson": "^2.2.6",
        "zod": "catalog:",
        "zod-form-data": "^3.0.1"
    },
    "devDependencies": {
        "@11ty/gray-matter": "^2.1.0",
        "@autonoma/integration-test": "workspace:*",
        "@aws-sdk/client-s3": "^3.995.0",
        "@testcontainers/localstack": "^11.12.0",
        "@testcontainers/postgresql": "^11.12.0",
        "@testcontainers/redis": "^11.12.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "catalog:",
        "aws-sdk-client-mock": "^4.1.0",
        "rollup": "^4.60.0",
        "tsup": "^8.5.1",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
