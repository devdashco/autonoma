{
    "name": "@autonoma-ai/planner",
    "version": "0.1.13",
    "description": "Autonoma test planner - generate E2E test cases for any frontend codebase.",
    "bin": {
        "autonoma-planner": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "type": "module",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "eval:classifier": "tsx evals/failure-classifier.eval.ts",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint src tests evals",
        "fmt": "oxfmt --write src tests evals",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "@clack/core": "^1.3.1",
        "@clack/prompts": "^1.3.0",
        "@openrouter/ai-sdk-provider": "^2.9.0",
        "@t3-oss/env-core": "catalog:",
        "ai": "catalog:",
        "cross-spawn": "^7.0.6",
        "glob": "^13.0.6",
        "gray-matter": "^4.0.3",
        "highlight.js": "^11.11.1",
        "minimatch": "^10.0.0",
        "which": "^5.0.0",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/cross-spawn": "^6.0.6",
        "@types/node": "catalog:",
        "@types/which": "^3.0.4",
        "tsup": "^8.3.5",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "engines": {
        "node": ">=24"
    }
}
