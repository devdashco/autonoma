{
    "name": "@autonoma/worker-diffs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.eval.json",
        "lint": "oxlint --fix src/ evals/",
        "fmt": "oxfmt --write src/ evals/",
        "start": "tsx --import ./src/preload.ts src/index.ts",
        "test": "vitest run --passWithNoTests",
        "eval": "RUN_EVALS=true vitest run --passWithNoTests",
        "capture:analysis": "tsx --env-file=../../../.env evals/capture/capture.ts",
        "review:generation": "tsx --env-file=../../../.env src/review/generation/run-generation-review.ts",
        "review:replay": "tsx --env-file=../../../.env src/review/replay/run-replay-review.ts",
        "diffs-agent": "tsx --env-file=../../../.env src/local-dev/run-diffs-isolated.ts",
        "resolution-agent": "tsx --env-file=../../../.env src/local-dev/run-resolution-isolated.ts",
        "full-pipeline": "tsx --env-file=../../../.env src/local-dev/run-full-pipeline-isolated.ts",
        "generate-fixtures": "tsx --env-file=../../../.env src/local-dev/run-generate-fixtures.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/billing": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/diffs": "workspace:*",
        "@autonoma/engine": "workspace:*",
        "@autonoma/engine-web": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/image": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/test-updates": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@autonoma/workflow": "workspace:*",
        "@google/genai": "^1.42.0",
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "@temporalio/activity": "catalog:",
        "@temporalio/worker": "catalog:",
        "ai": "catalog:",
        "gray-matter": "^4.0.3",
        "playwright": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
