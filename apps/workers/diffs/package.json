{
    "name": "@autonoma/worker-diffs",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.eval.json",
        "lint": "oxlint --fix src/ evals/ test/",
        "fmt": "oxfmt --write src/ evals/ test/",
        "start": "tsx --import ./src/preload.ts src/index.ts",
        "test": "vitest run --passWithNoTests",
        "eval": "RUN_EVALS=true vitest run --passWithNoTests",
        "capture:analysis": "tsx --env-file=../../../.env evals/capture/capture-analysis-cli.ts",
        "capture:resolution": "tsx --env-file=../../../.env evals/capture/capture-resolution-cli.ts",
        "capture:generation-review": "tsx --env-file=../../../.env evals/capture/capture-generation-review.ts",
        "capture:replay-review": "tsx --env-file=../../../.env evals/capture/capture-replay-review.ts",
        "capture:healing": "tsx --env-file=../../../.env evals/capture/capture-healing-cli.ts"
    },
    "dependencies": {
        "@autonoma/ai": "workspace:*",
        "@autonoma/billing": "workspace:*",
        "@autonoma/db": "workspace:*",
        "@autonoma/diffs": "workspace:*",
        "@autonoma/engine": "workspace:*",
        "@autonoma/engine-web": "workspace:*",
        "@autonoma/evals": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/image": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/test-updates": "workspace:*",
        "@autonoma/types": "workspace:*",
        "@autonoma/workflow": "workspace:*",
        "@google/genai": "^1.42.0",
        "@sentry/node": "catalog:",
        "@t3-oss/env-core": "catalog:",
        "@temporalio/activity": "catalog:",
        "@temporalio/worker": "catalog:",
        "ai": "catalog:",
        "gray-matter": "^4.0.3",
        "playwright": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@autonoma/integration-test": "workspace:*",
        "@testcontainers/postgresql": "^11.12.0",
        "@types/node": "catalog:",
        "dotenv": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
