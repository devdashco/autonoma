{
    "name": "@autonoma/previewkit",
    "version": "0.1.0",
    "private": true,
    "description": "Preview environments for pull requests - deploy any stack to Kubernetes",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --import ./src/worker/preload.ts src/worker/index.ts",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
        "test:kind": "vitest run --config vitest.kind.config.ts",
        "typecheck": "tsc --noEmit",
        "migrate:config": "tsx scripts/migrate-yaml-to-db.ts",
        "start:worker": "tsx --import ./src/worker/preload.ts src/worker/index.ts"
    },
    "dependencies": {
        "@autonoma/db": "workspace:*",
        "@autonoma/github": "workspace:*",
        "@autonoma/logger": "workspace:*",
        "@autonoma/storage": "workspace:*",
        "@autonoma/utils": "workspace:*",
        "@autonoma/workflow": "workspace:*",
        "@aws-crypto/sha256-js": "^5.2.0",
        "@aws-sdk/client-ecr": "^3.1048.0",
        "@aws-sdk/client-eks": "^3.1048.0",
        "@aws-sdk/client-s3": "^3.995.0",
        "@aws-sdk/client-secrets-manager": "^3.1048.0",
        "@aws-sdk/credential-provider-node": "^3.972.42",
        "@aws-sdk/credential-providers": "^3.1048.0",
        "@kubernetes/client-node": "catalog:",
        "@octokit/app": "catalog:",
        "@sentry/node": "catalog:",
        "@smithy/protocol-http": "^5.3.14",
        "@smithy/signature-v4": "^5.3.14",
        "@t3-oss/env-core": "catalog:",
        "@temporalio/activity": "catalog:",
        "@temporalio/worker": "catalog:",
        "ioredis": "^5.9.3",
        "js-yaml": "^4.1.1",
        "tar-fs": "^3.1.2",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@autonoma/integration-test": "workspace:*",
        "@testcontainers/postgresql": "^11.12.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "catalog:",
        "@types/tar-fs": "^2.0.4",
        "@vitest/coverage-v8": "^4.1.6",
        "dotenv": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
