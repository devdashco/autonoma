{
    "name": "@autonoma/agent",
    "version": "1.8.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "ui": "turbo run dev --filter=@autonoma/ui",
        "dev": "turbo run dev --parallel --filter @autonoma/ui --filter @autonoma/api",
        "api": "turbo run dev --filter=@autonoma/api",
        "docs": "turbo run dev --filter=@autonoma/docs",
        "lint": "turbo run lint --continue",
        "fmt": "turbo run fmt",
        "format": "oxfmt --write .",
        "check": "oxlint --fix . && oxfmt --write .",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate --filter=@autonoma/db",
        "agent:execute": "pnpm --filter @autonoma/api agent:execute",
        "db:restore": "tsx scripts/restore-db-from-backup.ts",
        "prepare": "husky",
        "fetch-secret": "node -e \"import('@autonoma-ai/envsync').then(({ saveSecretToEnv }) => saveSecretToEnv())\""
    },
    "devDependencies": {
        "@autonoma-ai/envsync": "^2.0.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "oxfmt": "0.42.0",
        "oxlint": "1.57.0",
        "tsx": "catalog:",
        "turbo": "^2.9.18",
        "typescript": "catalog:",
        "zod": "catalog:"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "oxlint --fix",
            "oxfmt --write"
        ],
        "*.{json,jsonc}": [
            "oxfmt --write"
        ]
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
    "envsync": {
        "secretName": "dev/agent",
        "envFile": ".env",
        "region": "us-east-1"
    }
}
