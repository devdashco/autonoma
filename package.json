{
    "name": "@autonoma/agent",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "ui": "turbo run dev --filter=@autonoma/ui",
        "dev": "turbo run dev --parallel --filter @autonoma/ui --filter @autonoma/api",
        "api": "turbo run dev --filter=@autonoma/api",
        "docs": "turbo run dev --filter=@autonoma/docs",
        "lint": "turbo run lint --continue",
        "fmt": "turbo run fmt",
        "format": "oxfmt --write .",
        "check": "oxlint --fix . && oxfmt --write .",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate",
        "agent:execute": "pnpm --filter @autonoma/api agent:execute",
        "db:restore": "tsx scripts/restore-db-from-backup.ts",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "oxfmt": "0.42.0",
        "oxlint": "1.57.0",
        "tsx": "catalog:",
        "turbo": "^2.3.0",
        "typescript": "catalog:"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "oxlint --fix",
            "oxfmt --write"
        ],
        "*.{json,jsonc}": [
            "oxfmt --write"
        ]
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/engines",
            "core-js",
            "cpu-features",
            "esbuild",
            "prisma",
            "protobufjs",
            "sharp",
            "ssh2"
        ],
        "overrides": {
            "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
            "hono@<4.11.7": ">=4.11.7",
            "hono@<4.11.10": ">=4.11.10",
            "serialize-javascript@<=7.0.2": ">=7.0.3",
            "hono@<4.12.4": ">=4.12.4",
            "fast-xml-parser@>=5.0.0 <5.3.8": ">=5.3.8",
            "@hono/node-server@<1.19.10": ">=1.19.10",
            "hono@<4.12.7": ">=4.12.7",
            "fast-xml-parser@>=5.0.0 <5.5.6": ">=5.5.6",
            "effect@<3.20.0": ">=3.20.0",
            "serialize-javascript@<7.0.5": ">=7.0.5",
            "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
            "lodash@<=4.17.23": ">=4.18.0",
            "defu@<=6.1.4": ">=6.1.5",
            "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
            "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
            "hono@<4.12.12": ">=4.12.12",
            "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
            "@hono/node-server@<1.19.13": ">=1.19.13",
            "fast-xml-parser@>=5.0.0 <5.5.7": ">=5.5.7",
            "basic-ftp@<=5.2.1": ">=5.2.2",
            "basic-ftp@=5.2.0": ">=5.2.1",
            "follow-redirects@<=1.15.11": ">=1.16.0",
            "dompurify@<=3.3.3": ">=3.4.0",
            "hono@<4.12.14": ">=4.12.14",
            "axios@>=1.0.0 <1.15.0": ">=1.15.0",
            "basic-ftp@<=5.2.2": ">=5.3.0",
            "protobufjs@<7.5.5": ">=7.5.5"
        }
    }
}
