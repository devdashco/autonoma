{
    "name": "@autonoma/agent",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "ui": "turbo run dev --filter=@autonoma/ui",
        "dev": "turbo run dev --parallel --filter @autonoma/ui --filter @autonoma/api",
        "sb": "pnpm --filter @autonoma/pond-ui storybook",
        "api": "turbo run dev --filter=@autonoma/api",
        "docs": "turbo run dev --filter=@autonoma/docs",
        "lint": "turbo run lint --continue",
        "fmt": "turbo run fmt",
        "format": "oxfmt --write .",
        "check": "oxlint --fix . && oxfmt --write .",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "db:generate": "turbo run db:generate",
        "db:migrate": "turbo run db:migrate",
        "agent:execute": "pnpm --filter @autonoma/api agent:execute",
        "db:restore": "tsx scripts/restore-db-from-backup.ts",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "oxfmt": "0.42.0",
        "oxlint": "1.57.0",
        "tsx": "catalog:",
        "turbo": "^2.3.0",
        "typescript": "catalog:"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "oxlint --fix",
            "oxfmt --write"
        ],
        "*.{json,jsonc}": [
            "oxfmt --write"
        ]
    },
    "engines": {
        "node": ">=24"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/engines",
            "core-js",
            "cpu-features",
            "esbuild",
            "prisma",
            "protobufjs",
            "sharp",
            "ssh2"
        ]
    }
}
